# Session encryption key (min 32 characters, required for production)
SESSION_SECRET=change-me-to-a-random-string-at-least-32-chars

# Optional pepper appended to passwords before bcrypt hashing
AUTH_PEPPER=

# SMTP for password reset emails (optional)
# SMTP_URL=smtp://user:pass@mail.example.com:587
SMTP_URL=
SMTP_FROM=noreply@localhost

# Docker bind address (default: 0.0.0.0, use 172.17.0.1 to restrict to Docker bridge)
BIND_ADDRESS=0.0.0.0

# Server port
PORT=6175
